  } else if(sp.id === 'rugby'){
    // 15 vs 15, simplified to 8 vs 8
    [[.1,.5],[.22,.3],[.22,.5],[.22,.7],[.34,.25],[.34,.5],[.34,.75],[.46,.5]].forEach(([xr,yr])=>
      entities.push({x:xr*w,y:yr*h,vx:(Math.random()-.5)*.4,vy:(Math.random()-.5)*.4,team:0,r:h*.028,homeX:xr*w,homeY:yr*h,hasBall:false}));
    [[.9,.5],[.78,.3],[.78,.5],[.78,.7],[.66,.25],[.66,.5],[.66,.75],[.54,.5]].forEach(([xr,yr])=>
      entities.push({x:xr*w,y:yr*h,vx:(Math.random()-.5)*.4,vy:(Math.random()-.5)*.4,team:1,r:h*.028,homeX:xr*w,homeY:yr*h,hasBall:false}));
