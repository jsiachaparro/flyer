    // batter + runner
    entities.push({x:w*.5,y:h*.82,vx:0,vy:0,team:1,r:h*.03,homeX:w*.5,homeY:h*.82,hasBall:false});
    entities.push({x:w*.35,y:h*.58,vx:0,vy:0,team:1,r:h*.03,homeX:w*.35,homeY:h*.58,hasBall:false});
