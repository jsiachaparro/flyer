/* ─── SCOREBOARD UPDATER ─── */
function updateScoreboard(idx){
  var sp = SPORTS[idx];
  var sb = document.getElementById('scoreboard');
  if(!sb) return;

  var scoreParts = sp.score.split('—');
  var homeScore = scoreParts[0] ? scoreParts[0].trim() : sp.score;
  var awayScore = scoreParts[1] ? scoreParts[1].trim() : '-';

  sb.innerHTML =
    '<div style="display:flex;align-items:center;gap:clamp(3px,.5vw,8px);padding:clamp(3px,.5vw,8px) clamp(5px,.8vw,14px);background:rgba(255,255,255,.06);font-family:\'Bebas Neue\',sans-serif;font-size:clamp(9px,1.6vw,20px)">' +
      '<span style="font-size:clamp(7px,1vw,14px)">'+ HOME_ICONS[idx] +'</span>' +
      '<span style="color:#fff">'+ sp.teams[0] +'</span>' +
    '</div>' +
    '<div style="display:flex;align-items:center;background:rgba(0,0,0,.4);">' +
      '<div style="padding:clamp(3px,.5vw,8px) clamp(6px,1vw,16px);background:var(--signal);color:#fff;font-family:\'Bebas Neue\',sans-serif;font-size:clamp(11px,2vw,26px)">'+ homeScore +'</div>' +
      '<div style="padding:0 clamp(4px,.6vw,10px);color:rgba(255,255,255,.35);font-family:\'Bebas Neue\',sans-serif;font-size:clamp(9px,1.4vw,16px)">—</div>' +
      '<div style="padding:clamp(3px,.5vw,8px) clamp(6px,1vw,16px);background:#444;color:#fff;font-family:\'Bebas Neue\',sans-serif;font-size:clamp(11px,2vw,26px)">'+ awayScore +'</div>' +
    '</div>' +
    '<div style="display:flex;align-items:center;gap:clamp(3px,.5vw,8px);padding:clamp(3px,.5vw,8px) clamp(5px,.8vw,14px);background:rgba(255,255,255,.06);font-family:\'Bebas Neue\',sans-serif;font-size:clamp(9px,1.6vw,20px)">' +
      '<span style="color:#fff">'+ sp.teams[1] +'</span>' +
      '<span style="font-size:clamp(7px,1vw,14px)">'+ AWAY_ICONS[idx] +'</span>' +
    '</div>' +
    '<div style="padding:clamp(3px,.5vw,8px) clamp(5px,.8vw,12px);background:rgba(255,45,0,.15);border-left:1px solid rgba(255,45,0,.3);display:flex;align-items:center;gap:4px;">' +
      '<span style="width:5px;height:5px;background:var(--signal);border-radius:50%;display:inline-block;animation:blink 1s infinite;flex-shrink:0"></span>' +
      '<span id="matchMinute" style="color:var(--warm);font-family:\'Bebas Neue\',sans-serif;font-size:clamp(8px,1.2vw,15px)">'+ sp.time +'</span>' +
    '</div>';

  // ticker
  var tickerEl = document.getElementById('matchTicker');
  if(tickerEl) tickerEl.innerHTML = TICKERS[sp.id] || TICKERS.soccer;

  // reset signage slides for this sport
  activeSignageSlides = SIGNAGE_BY_SPORT[sp.id] || SIGNAGE_BY_SPORT.soccer;
  signageIdx = 0;
  var s = activeSignageSlides[0];
  var card = document.getElementById('signageCard');
  if(card && s){
    document.getElementById('signageIcon').textContent  = s.icon;
    document.getElementById('signageLabel').textContent = s.label;
    document.getElementById('signageText').textContent  = s.text;
    document.getElementById('signagePill').textContent  = s.pill;
  }
}

/* ─── SPORT TRANSITION SYSTEM ─── */
var transitionAlpha=0;
var isTransitioning=false;
var pendingSport=-1;

function triggerTransition(nextIdx){
  if(isTransitioning)return;
  isTransitioning=true;pendingSport=nextIdx;transitionAlpha=0;
}

// draw flash overlay during transition
function drawTransition(){
  if(!isTransitioning)return;
  transitionAlpha+=.06;
  const eased=transitionAlpha<.5?transitionAlpha*2:(2-transitionAlpha*2);
  ctx.fillStyle=`rgba(0,0,0,${Math.min(1,transitionAlpha*2)})`;
  ctx.fillRect(0,0,W(),H());
  if(transitionAlpha>=.5 && pendingSport>=0){
    currentSport=pendingSport;
    pendingSport=-1;
    initSport(currentSport);
    updateScoreboard(currentSport);
    const gf=document.getElementById('goalFlash');
    const gt=document.getElementById('goalText');
    if(gf&&gt){
      const SPORT=SPORTS[currentSport];
      const msgs={soccer:'⚽ GOOOL!',basketball:'🏀 SCORE!',baseball:'⚾ HOME RUN!',rugby:'🏉 TRY!',ufc:'👊 KO!'};
      gt.textContent=msgs[SPORT.id]||'SCORE!';
    }
  }
  if(transitionAlpha>=1){ isTransitioning=false;transitionAlpha=0; }
}

// Sport name banner during switch
let bannerAlpha=0,bannerSport='';
function showBanner(name){bannerSport=name;bannerAlpha=1;}
function drawBanner(){
  if(bannerAlpha<=0)return;
  bannerAlpha-=.018;
  const w=W(),h=H();
  ctx.save();
  ctx.globalAlpha=Math.min(1,bannerAlpha*3);
  ctx.fillStyle='rgba(0,0,0,.75)';
  const bh=h*.22;
  ctx.fillRect(0,h/2-bh/2,w,bh);
  ctx.fillStyle=SPORTS[currentSport].accent;
  ctx.font=`900 ${Math.max(16,h*.14)}px 'Bebas Neue',sans-serif`;
  ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.letterSpacing='.1em';
  ctx.fillText(bannerSport,w/2,h/2);
  ctx.restore();
}

/* ─── MAIN LOOP ─── */
let sportClock=0;
const SPORT_MS=3000;

function loop(ts){
  const w=W(),h=H();
  ctx.clearRect(0,0,w,h);

  // draw sport background
  const sp=SPORTS[currentSport];
  if(sp.id==='soccer')drawSoccer();
  else if(sp.id==='basketball')drawBasketball();
  else if(sp.id==='baseball')drawBaseball();
  else if(sp.id==='rugby')drawRugby();
  else if(sp.id==='ufc')drawUFC();
  else if(sp.id==='nfl')drawNFL();

  // update + draw entities
  updateEntities(sp.id);
  entities.forEach(p=>drawPlayer(p,sp.id));

  // draw ball
  if(sp.id==='soccer')drawBallSoccer();
  else if(sp.id==='basketball')drawBallBasketball();
  else if(sp.id==='baseball')drawBallBaseball();
  else if(sp.id==='rugby')drawBallRugby();
  else if(sp.id==='nfl')drawBallNFL();

  // subtle crowd glow flicker
  const flicker=(Math.sin(ts*.003)*.5+.5)*.025;
  ctx.fillStyle=`rgba(255,220,80,${flicker})`;ctx.fillRect(0,0,w,h);

  drawTransition();
  drawBanner();

  // sport rotation timer
  sportClock+=(ts-lastTs)||16;
  if(sportClock>=SPORT_MS&&!isTransitioning){
    sportClock=0;
    const next=(currentSport+1)%SPORTS.length;
    triggerTransition(next);
    showBanner(SPORTS[next].label);
  }
  lastTs=ts;
  requestAnimationFrame(loop);
}

let lastTs=0;
updateScoreboard(0);
requestAnimationFrame(ts=>{lastTs=ts;loop(ts);});

