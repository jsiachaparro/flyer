  if(ns) ns.textContent = '0:' + String(signageNextCount).padStart(2,'0');

  if(signageNextCount <= 0){
    var slides = activeSignageSlides.length ? activeSignageSlides : [
      {icon:'🎁',label:'PATROCINADOR OFICIAL',text:'OFERTA EN VIVO',pill:'↗ ESCANEA'},
    ];
    signageIdx = (signageIdx + 1) % slides.length;
    var s = slides[signageIdx];
    var card = document.getElementById('signageCard');
    if(card){
      card.style.opacity='0'; card.style.transform='translateY(8px)';
      setTimeout(function(){
        document.getElementById('signageIcon').textContent  = s.icon;
        document.getElementById('signageLabel').textContent = s.label;
        document.getElementById('signageText').textContent  = s.text;
        document.getElementById('signagePill').textContent  = s.pill;
        siDots.forEach(function(d,i){ if(d) d.classList.toggle('active', i === signageIdx % 4); });
        card.style.opacity='1'; card.style.transform='translateY(0)';
      }, 350);
    }
    signageNextCount = 10;
  }
}, 1000);

