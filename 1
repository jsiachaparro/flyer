/* ─── PLAYER DRAWING ─── */
function drawPlayer(p, sport){
  ctx.save();ctx.translate(p.x,p.y);
  // shadow
  ctx.fillStyle='rgba(0,0,0,.18)';ctx.beginPath();ctx.ellipse(0,p.r*.8,p.r*.85,p.r*.28,0,0,Math.PI*2);ctx.fill();

  if(sport==='soccer'){
    var sc=[[255,255,255],[0,77,152]];
    ctx.fillStyle='rgb('+sc[p.team]+')';
    ctx.beginPath();ctx.arc(0,0,p.r,0,Math.PI*2);ctx.fill();
    if(p.team===1){ctx.fillStyle='#A50044';ctx.beginPath();ctx.arc(0,0,p.r,-.4,Math.PI+.4);ctx.arc(0,0,p.r*.44,Math.PI+.4,-.4,true);ctx.fill();}
    ctx.fillStyle=p.team===0?'#1a5c1a':'#fff';

  } else if(sport==='basketball'){
    var bc=[['#702963','#FDB927'],['#007A33','#BA9653']];
    ctx.fillStyle=bc[p.team][0];ctx.beginPath();ctx.arc(0,0,p.r,0,Math.PI*2);ctx.fill();
    ctx.fillStyle=bc[p.team][1];ctx.beginPath();ctx.arc(0,0,p.r*.45,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#fff';

  } else if(sport==='baseball'){
    ctx.fillStyle=p.team===0?'#132448':'#C6011F';
    ctx.beginPath();ctx.arc(0,0,p.r,0,Math.PI*2);ctx.fill();
    ctx.fillStyle=p.team===0?'#132448':'#C6011F';
    ctx.beginPath();ctx.ellipse(0,-p.r*.6,p.r*.7,p.r*.25,0,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#fff';

  } else if(sport==='rugby'){
    ctx.fillStyle=p.team===0?'#fff':'#169b62';
    ctx.beginPath();ctx.arc(0,0,p.r,0,Math.PI*2);ctx.fill();
    if(p.team===1){ctx.fillStyle='#FF6B00';ctx.beginPath();ctx.arc(0,0,p.r*.4,0,Math.PI*2);ctx.fill();}
    ctx.fillStyle=p.team===0?'#333':'#fff';

  } else if(sport==='ufc'){
    p.phase=(p.phase||0)+.04;
    var bob=Math.sin(p.phase)*p.r*.15;
    ctx.fillStyle=p.team===0?'#1a3a6a':'#6a1a1a';
    ctx.beginPath();ctx.arc(0,bob,p.r,0,Math.PI*2);ctx.fill();
    var gColor=p.team===0?'#FF4500':'#1E90FF';
    ctx.fillStyle=gColor;
    var gAngle=Math.sin(p.phase*1.3)*.5;
    ctx.beginPath();ctx.arc(Math.cos(gAngle)*p.r*.7,Math.sin(gAngle)*p.r*.7+bob,p.r*.32,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(-Math.cos(gAngle+.8)*p.r*.6,-Math.sin(gAngle+.8)*p.r*.4+bob,p.r*.28,0,Math.PI*2);ctx.fill();
    var hg=ctx.createRadialGradient(0,bob-p.r*.3,0,0,bob-p.r*.3,p.r*.3);
    hg.addColorStop(0,p.team===0?'rgba(100,150,255,.35)':'rgba(255,100,100,.35)');hg.addColorStop(1,'transparent');
    ctx.fillStyle=hg;ctx.beginPath();ctx.arc(0,bob-p.r*.3,p.r*.4,0,Math.PI*2);ctx.fill();
    ctx.restore();return;

  } else if(sport==='nfl'){
    // Steelers black+gold  vs  Patriots navy+red — similar style to rugby
    ctx.fillStyle=p.team===0?'#101010':'#002244';
    ctx.beginPath();ctx.arc(0,0,p.r,0,Math.PI*2);ctx.fill();
    // color stripe across middle (like rugby band)
    ctx.fillStyle=p.team===0?'#FFB612':'#C60C30';
    ctx.beginPath();ctx.arc(0,0,p.r,-.45,Math.PI+.45);ctx.arc(0,0,p.r*.5,Math.PI+.45,-.45,true);ctx.fill();
    // shoulder pads oval
    ctx.fillStyle=p.team===0?'rgba(255,182,18,.3)':'rgba(198,12,48,.3)';
    ctx.beginPath();ctx.ellipse(0,-p.r*.18,p.r*.88,p.r*.4,0,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#fff';
    ctx.restore();return;
  }

  // jersey number (soccer/basketball/baseball/rugby)
  ctx.font='bold '+Math.max(5,p.r*.65)+'px monospace';
  ctx.textAlign='center';ctx.textBaseline='middle';
  if(!p._num)p._num=Math.floor(Math.random()*30+1);
  ctx.fillText(p.hasBall?'★':p._num,0,0);
  ctx.restore();
}

/* ─── PHYSICS UPDATE ─── */
function updateEntities(sport){
  const w=W(),h=H();
  const mx=w*.04,my=h*.05,fw=w*.92,fh=h*.9;

  if(sport==='ufc'){
    // two fighters circling each other
    entities.forEach((f,i)=>{
      const other=entities[1-i];
      const dx=other.x-f.x, dy=other.y-f.y;
      const dist=Math.sqrt(dx*dx+dy*dy);
      const targetDist=f.r*3;
      // approach / back off
      if(dist>targetDist*1.5){f.vx+=dx/dist*.08;f.vy+=dy/dist*.08;}
      else if(dist<targetDist*.7){f.vx-=dx/dist*.1;f.vy-=dy/dist*.1;}
      // orbit
      f.vx+=-dy/dist*.05+(Math.random()-.5)*.06;
      f.vy+=dx/dist*.05+(Math.random()-.5)*.06;
      const spd=Math.sqrt(f.vx*f.vx+f.vy*f.vy);
      if(spd>1.2){f.vx=f.vx/spd*1.2;f.vy=f.vy/spd*1.2;}
      f.x+=f.vx;f.y+=f.vy;
      const oct=Math.min(w,h)*.38;
      const fx=f.x-w/2,fy=f.y-h/2;
      if(Math.sqrt(fx*fx+fy*fy)>oct){
        const a=Math.atan2(fy,fx);f.x=w/2+oct*Math.cos(a)*.95;f.y=h/2+oct*Math.sin(a)*.95;f.vx*=-.5;f.vy*=-.5;
      }
    });
    return;
  }

  entities.forEach((p,i)=>{
    const homeX=p.homeX, homeY=p.homeY;
    p.vx+=(homeX-p.x)*.004+(Math.random()-.5)*.14;
    p.vy+=(homeY-p.y)*.004+(Math.random()-.5)*.14;
    const spd=Math.sqrt(p.vx*p.vx+p.vy*p.vy);
    const maxSpd=sport==='basketball'?2.2:sport==='baseball'?0.4:sport==='nfl'?1.2:1.8;
    if(spd>maxSpd){p.vx=p.vx/spd*maxSpd;p.vy=p.vy/spd*maxSpd;}
    p.x+=p.vx;p.y+=p.vy;
    if(p.x<mx+p.r){p.x=mx+p.r;p.vx*=-.6;}
    if(p.x>mx+fw-p.r){p.x=mx+fw-p.r;p.vx*=-.6;}
    if(p.y<my+p.r){p.y=my+p.r;p.vy*=-.6;}
    if(p.y>my+fh-p.r){p.y=my+fh-p.r;p.vy*=-.6;}
    if(p.hasBall){
      if(sport==='rugby'){ball.x=p.x+p.vx*2;ball.y=p.y+p.vy*2;}
      else{ball.x=p.x+p.vx*2.2;ball.y=p.y+p.vy*2.2;}
    }
  });

  // ball free physics
  const carrier=entities.find(p=>p.hasBall);
  if(!carrier && ball.r||ball.rw){
    ball.x+=ball.vx;ball.y+=ball.vy;
    if(sport==='baseball'){ball.vy+=.08;} // gravity
    ball.vx*=.985;ball.vy*=.985;
    if(ball.x<mx+ball.r){ball.x=mx+(ball.r||10);ball.vx*=-.8;}
    if(ball.x>mx+fw-ball.r){ball.x=mx+fw-(ball.r||10);ball.vx*=-.8;}
    if(ball.y<my+ball.r){ball.y=my+(ball.r||10);ball.vy*=-.8;}
    if(ball.y>my+fh-ball.r){ball.y=my+fh-(ball.r||10);ball.vy*=-.75;}
    // pickup
    entities.forEach(p=>{
      const dx=p.x-ball.x,dy=p.y-ball.y;
      if(Math.sqrt(dx*dx+dy*dy)<p.r+(ball.r||ball.rw||10)+3){
        entities.forEach(q=>q.hasBall=false);p.hasBall=true;
      }
    });
  }

  // random pass
  if(Math.random()<(sport==='rugby'?.003:.005)){
    const carrierIdx=entities.findIndex(p=>p.hasBall);
    if(carrierIdx>=0){
      const t=entities[carrierIdx].team;
      const mates=entities.filter((q,j)=>j!==carrierIdx&&q.team===t);
      if(mates.length){
        entities.forEach(q=>q.hasBall=false);
        const tgt=mates[Math.floor(Math.random()*mates.length)];
        const dx=tgt.x-ball.x,dy=tgt.y-ball.y,d=Math.sqrt(dx*dx+dy*dy)||1;
        const spd=sport==='baseball'?6:sport==='basketball'?5:sport==='nfl'?5:4;
        ball.vx=dx/d*spd;ball.vy=dy/d*spd;
        ball.spin=sport==='basketball'?.12:sport==='soccer'?.05:.015;
      }
    }
  }
}

