/* ─── DRAW BACKGROUNDS ─── */
function drawSoccer(){
  const w=W(),h=H();
  // grass + stripes
  ctx.fillStyle='#1d5c1d'; ctx.fillRect(0,0,w,h);
  for(let i=0;i<14;i++){
    ctx.fillStyle=i%2===0?'rgba(0,0,0,.05)':'rgba(255,255,255,.025)';
    ctx.fillRect(i*w/14,0,w/14,h);
  }
  ctx.strokeStyle='rgba(255,255,255,.5)'; ctx.lineWidth=1.4;
  const mx=w*.04,my=h*.05,fw=w*.92,fh=h*.9;
  ctx.strokeRect(mx,my,fw,fh);
  ctx.beginPath();ctx.moveTo(w/2,my);ctx.lineTo(w/2,my+fh);ctx.stroke();
  ctx.beginPath();ctx.arc(w/2,h/2,h*.22,0,Math.PI*2);ctx.stroke();
  ctx.fillStyle='rgba(255,255,255,.55)';ctx.beginPath();ctx.arc(w/2,h/2,2.5,0,Math.PI*2);ctx.fill();
  const pbW=w*.16,pbH=h*.54;
  ctx.strokeRect(mx,h/2-pbH/2,pbW,pbH);ctx.strokeRect(mx+fw-pbW,h/2-pbH/2,pbW,pbH);
  const gbW=w*.07,gbH=h*.28;
  ctx.strokeRect(mx,h/2-gbH/2,gbW,gbH);ctx.strokeRect(mx+fw-gbW,h/2-gbH/2,gbW,gbH);
  // goals
  ctx.strokeStyle='rgba(255,255,255,.7)'; ctx.lineWidth=2;
  const gDepth=w*.022, gHalf=h*.14;
  ctx.strokeRect(mx-gDepth,h/2-gHalf,gDepth,gHalf*2);
  ctx.strokeRect(mx+fw,h/2-gHalf,gDepth,gHalf*2);
}

function drawBasketball(){
  const w=W(),h=H();
  // hardwood floor
  ctx.fillStyle='#8B5E3C'; ctx.fillRect(0,0,w,h);
  // floorboard lines
  ctx.strokeStyle='rgba(0,0,0,.12)'; ctx.lineWidth=1;
  for(let i=0;i<20;i++){
    ctx.beginPath();ctx.moveTo(0,i*h/20);ctx.lineTo(w,i*h/20);ctx.stroke();
  }
  ctx.strokeStyle='rgba(255,255,255,.6)'; ctx.lineWidth=1.5;
  const mx=w*.03,my=h*.04,fw=w*.94,fh=h*.92;
  ctx.strokeRect(mx,my,fw,fh);
  ctx.beginPath();ctx.arc(w/2,h/2,h*.18,0,Math.PI*2);ctx.stroke();
  ctx.beginPath();ctx.moveTo(w/2,my);ctx.lineTo(w/2,my+fh);ctx.stroke();
  // key areas (paint)
  ctx.fillStyle='rgba(200,50,50,.25)';
  const keyW=w*.18,keyH=h*.65;
  ctx.fillRect(mx,h/2-keyH/2,keyW,keyH);
  ctx.fillRect(mx+fw-keyW,h/2-keyH/2,keyW,keyH);
  ctx.strokeStyle='rgba(255,255,255,.5)';
  ctx.strokeRect(mx,h/2-keyH/2,keyW,keyH);
  ctx.strokeRect(mx+fw-keyW,h/2-keyH/2,keyW,keyH);
  // free throw circles
  ctx.beginPath();ctx.arc(mx+keyW,h/2,h*.12,0,Math.PI*2);ctx.stroke();
  ctx.beginPath();ctx.arc(mx+fw-keyW,h/2,h*.12,0,Math.PI*2);ctx.stroke();
  // hoops
  const hoopY=h*.5, hoopR=h*.04;
  [mx+keyW*.05, mx+fw-keyW*.05].forEach(hx=>{
    ctx.strokeStyle='#FF6B00'; ctx.lineWidth=2.5;
    ctx.beginPath();ctx.arc(hx,hoopY,hoopR,0,Math.PI*2);ctx.stroke();
    ctx.strokeStyle='rgba(255,255,255,.3)'; ctx.lineWidth=1;
    // backboard
    ctx.beginPath();ctx.moveTo(hx-hoopR*1.8,hoopY-hoopR*2.5);ctx.lineTo(hx+hoopR*1.8,hoopY-hoopR*2.5);ctx.stroke();
  });
}

function drawBaseball(){
  const w=W(),h=H();
  // outfield grass
  ctx.fillStyle='#1a4a1a'; ctx.fillRect(0,0,w,h);
  // infield dirt
  const cx2=w*.5,cy2=h*.65,ir=h*.38;
  ctx.fillStyle='#8B6914';
  ctx.beginPath();ctx.arc(cx2,cy2,ir,0,Math.PI*2);ctx.fill();
  // infield grass diamond
  ctx.fillStyle='#1e5c1e';
  ctx.beginPath();
  ctx.moveTo(cx2,cy2-ir*.58);  // 2nd base
  ctx.lineTo(cx2+ir*.55,cy2);  // 1st base
  ctx.lineTo(cx2,cy2+ir*.25);  // home
  ctx.lineTo(cx2-ir*.55,cy2);  // 3rd base
  ctx.closePath(); ctx.fill();
  // bases
  ctx.fillStyle='#fff';
  [[0,-1],[1,0],[0,1],[-1,0]].forEach(([bx,by],i)=>{
