<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SIGNAL — Digital Signage & Presencia de Marca</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Familjen+Grotesk:ital,wght@0,400;0,500;0,700;1,400&family=DM+Mono:wght@400;500&display=swap');

:root {
  --ink: #08080C;
  --paper: #F0EDE6;
  --signal: #FF2D00;
  --warm: #FFB800;
  --cool: #00C2FF;
  --dim: rgba(240,237,230,0.45);
  --card-bg: #0F0F16;
  --line: rgba(240,237,230,0.1);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:var(--ink);
  color:var(--paper);
  font-family:'Familjen Grotesk',sans-serif;
  overflow-x:hidden;
}

/* ── CURSOR ── */
#cur{width:10px;height:10px;background:var(--signal);border-radius:50%;position:fixed;pointer-events:none;z-index:9999;transition:transform .12s;mix-blend-mode:difference;transition:opacity .3s}
#cur2{width:32px;height:32px;border:1px solid var(--signal);border-radius:50%;position:fixed;pointer-events:none;z-index:9998;transition:all .2s ease;opacity:.6}
body *{cursor:none}
/* On touch devices: cursor visible only on finger contact */
@media (hover:none){
  #cur{opacity:0}
  #cur2{opacity:0}
  body *{cursor:auto}
}

/* ── SCANLINE overlay ── */
body::after{
  content:'';position:fixed;inset:0;
  background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.04) 3px,rgba(0,0,0,.04) 4px);
  pointer-events:none;z-index:9990;
}

/* ══════════════════════════════
   HERO
══════════════════════════════ */
.hero{
  min-height:100vh;
  display:grid;
  grid-template-rows:auto 1fr auto;
  position:relative;
  overflow:hidden;
}

/* Animated scoreboard BG */
.hero-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 40%, rgba(255,45,0,.12) 0%, transparent 55%),
    radial-gradient(ellipse 40% 30% at 80% 80%, rgba(255,184,0,.07) 0%, transparent 50%),
    var(--ink);
}
.ticker-bg{
  position:absolute;bottom:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,transparent,var(--signal),transparent);
  animation:tickerGlow 3s ease-in-out infinite;
}
@keyframes tickerGlow{0%,100%{opacity:.4;transform:scaleX(.6)}50%{opacity:1;transform:scaleX(1)}}

/* Big screen glow effect */
.screen-glow{
  position:absolute;
  width:70vw;max-width:900px;height:50vh;
  top:50%;left:50%;transform:translate(-50%,-52%);
  border:1px solid rgba(255,45,0,.15);
  box-shadow:
    0 0 80px rgba(255,45,0,.08),
    0 0 200px rgba(255,45,0,.04),
    inset 0 0 60px rgba(255,45,0,.03);
  animation:screenPulse 4s ease-in-out infinite;
}
@keyframes screenPulse{0%,100%{opacity:.5}50%{opacity:1}}

/* ── NAV ── */
nav{
  position:relative;z-index:10;
  display:flex;justify-content:space-between;align-items:center;
  padding:28px 60px;
  border-bottom:1px solid var(--line);
}
.nav-logo{
  font-family:'Bebas Neue',sans-serif;
  font-size:28px;letter-spacing:.12em;
}
.nav-logo span{color:var(--signal)}
.nav-badge{
  font-family:'DM Mono',monospace;
  font-size:10px;letter-spacing:.25em;
  color:var(--signal);
  border:1px solid rgba(255,45,0,.4);
  padding:5px 12px;
}
.nav-links{
  display:flex;gap:32px;
  font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.15em;color:var(--dim);
}
.nav-links span{transition:color .2s}
.nav-links span:hover{color:var(--paper)}

/* ── HERO CENTER ── */
.hero-center{
  position:relative;z-index:10;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  text-align:center;
  padding:40px 40px 0;
}
.hero-eyebrow{
  font-family:'DM Mono',monospace;
  font-size:11px;letter-spacing:.35em;color:var(--signal);
  margin-bottom:32px;
  animation:fadeUp .8s both;
}
.hero-h1{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(72px,13vw,200px);
  line-height:.88;
  letter-spacing:.02em;
  margin-bottom:0;
  animation:fadeUp .8s .1s both;
}
.hero-h1 .outline{
  -webkit-text-stroke:1.5px var(--paper);
  color:transparent;
}
.hero-h1 .red{color:var(--signal)}

.hero-sub{
  font-size:clamp(15px,2vw,20px);
  color:var(--dim);
  max-width:560px;
  line-height:1.65;
  margin-top:32px;
  animation:fadeUp .8s .2s both;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}

/* ── LIVE TICKER ── */
.hero-bottom{
  position:relative;z-index:10;
  border-top:1px solid var(--line);
  overflow:hidden;
}
.ticker-wrap{
  display:flex;
  white-space:nowrap;
  padding:14px 0;
  animation:tickerScroll 22s linear infinite;
}
@keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.ticker-item{
  font-family:'DM Mono',monospace;
  font-size:11px;letter-spacing:.2em;
  color:var(--dim);
  padding:0 48px;
  flex-shrink:0;
}
.ticker-item .dot{color:var(--signal);margin-right:12px}

/* ══════════════════════════════
   STATEMENT
══════════════════════════════ */
.statement{
  padding:140px 60px;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:80px;
  align-items:center;
  border-bottom:1px solid var(--line);
}
.stat-left{position:relative}
.stat-number{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(100px,18vw,240px);
  line-height:1;
  color:transparent;
  -webkit-text-stroke:1px rgba(240,237,230,.12);
  position:absolute;
  top:-30px;left:-20px;
  user-select:none;
}
.stat-headline{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(36px,5vw,68px);
  line-height:1;
  position:relative;z-index:1;
}
.stat-headline .hl{color:var(--warm)}
.stat-right{font-size:16px;color:var(--dim);line-height:1.8}
.stat-right p+p{margin-top:20px}
.stat-right strong{color:var(--paper);font-weight:500}

/* ══════════════════════════════
   LIVE DEMO SCREEN MOCKUP
══════════════════════════════ */
.demo-section{
  padding:0 60px 120px;
  position:relative;
}
.demo-label{
  font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.3em;
  color:var(--signal);margin-bottom:40px;padding-top:80px;
  border-top:1px solid var(--line);
}

.screen-mockup{
  position:relative;
  width:100%;
  aspect-ratio:16/5;
  background:#000;
  border:2px solid rgba(240,237,230,.08);
  overflow:hidden;
  box-shadow:0 0 120px rgba(255,45,0,.08);
}

/* LED scoreboard-style content panels */
.screen-grid{
  display:grid;
  grid-template-columns:1.2fr 2fr 1.2fr;
  height:100%;
  gap:2px;background:rgba(255,255,255,.03);
}
.screen-panel{
  position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:center;align-items:center;
  background:var(--ink);padding:20px;
}

/* Panel izquierdo — RELOJ */
.panel-clock{background:linear-gradient(135deg,#0a0a12,#13131e)}
.clock-time{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(32px,5vw,80px);
  color:var(--warm);
  letter-spacing:.05em;
  text-shadow:0 0 40px rgba(255,184,0,.5);
  animation:clockTick 1s step-end infinite;
}
@keyframes clockTick{50%{opacity:.85}}
.clock-date{
  font-family:'DM Mono',monospace;font-size:clamp(8px,1vw,12px);
  letter-spacing:.2em;color:var(--dim);margin-top:4px;
}
.clock-event{
  margin-top:10px;
  font-family:'DM Mono',monospace;font-size:clamp(7px,.9vw,10px);
  letter-spacing:.15em;color:var(--signal);
  border:1px solid rgba(255,45,0,.3);padding:3px 10px;
}

/* Panel centro — PROMO PRINCIPAL */
.panel-main{background:#08080C;position:relative;overflow:hidden}
.panel-main::before{
  content:'';position:absolute;inset:0;
  background:
    linear-gradient(135deg,rgba(255,45,0,.06),transparent 40%),
    linear-gradient(315deg,rgba(0,194,255,.04),transparent 40%);
}
.promo-tag{
  font-family:'DM Mono',monospace;font-size:clamp(7px,.8vw,10px);
  letter-spacing:.3em;color:var(--signal);margin-bottom:8px;
}
.promo-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(24px,4.5vw,72px);
  letter-spacing:.04em;
  line-height:1;
  text-align:center;
}
.promo-title .line2{color:var(--warm)}
.promo-sub{
  font-family:'DM Mono',monospace;font-size:clamp(6px,.75vw,10px);
  letter-spacing:.2em;color:var(--dim);margin-top:10px;text-align:center;
}
.promo-pill{
  margin-top:12px;
  background:var(--signal);
  color:#fff;
  font-family:'DM Mono',monospace;font-size:clamp(7px,.8vw,11px);
  letter-spacing:.15em;padding:5px 16px;
}

/* Panel derecho — INFO / QR */
.panel-info{background:linear-gradient(135deg,#0a0a12,#131319)}
.info-wifi{font-family:'DM Mono',monospace;font-size:clamp(7px,.8vw,10px);letter-spacing:.15em;color:var(--dim);text-align:center}
.info-wifi span{color:var(--cool);display:block;font-size:clamp(9px,1.2vw,14px);margin-top:3px}
.qr-box{
  width:clamp(40px,8vw,80px);height:clamp(40px,8vw,80px);
  border:1px solid rgba(0,194,255,.3);
  margin:10px auto;
  display:grid;grid-template-columns:repeat(5,1fr);grid-template-rows:repeat(5,1fr);gap:2px;
  padding:5px;
}
.qr-cell{background:rgba(0,194,255,.0)}
.qr-cell.on{background:var(--cool)}

.scroll-indicator{
  position:absolute;bottom:12px;left:0;right:0;
  display:flex;justify-content:center;gap:6px;
}
.si-dot{width:4px;height:4px;border-radius:50%;background:rgba(240,237,230,.2)}
.si-dot.active{background:var(--signal);animation:dotPulse 2s ease infinite}
@keyframes dotPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.5)}}

/* Content slides cycling */
.promo-content{position:relative}
.slide{position:absolute;top:0;left:0;width:100%;text-align:center;opacity:0;transition:opacity .8s ease}
.slide.show{opacity:1;position:relative}

/* Dimensions label */
.screen-label{
  display:flex;justify-content:space-between;align-items:center;
  margin-top:16px;
  font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.15em;color:rgba(240,237,230,.2);
}

/* ══════════════════════════════
   SECTORES
══════════════════════════════ */
.sectors{padding:120px 60px;border-top:1px solid var(--line)}
.sectors-header{margin-bottom:80px}
.sectors-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.3em;color:var(--signal);margin-bottom:20px}
.sectors-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(42px,6vw,88px);
  line-height:.95;
}
.sectors-title .grey{color:rgba(240,237,230,.25)}

.sectors-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:2px;
  background:var(--line);
}

.sector-card{
  background:var(--ink);
  padding:48px 40px;
  position:relative;
  overflow:hidden;
  transition:background .3s ease;
  display:grid;
  grid-template-rows:auto auto 1fr auto;
  gap:16px;
}
.sector-card:hover{background:var(--card-bg)}

/* Hover color bar */
.sector-card::before{
  content:'';
  position:absolute;
  top:0;left:0;right:0;height:3px;
  background:var(--sc,var(--signal));
  transform:scaleX(0);transform-origin:left;
  transition:transform .35s ease;
}
.sector-card:hover::before{transform:scaleX(1)}

.sc-num{
  font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.2em;
  color:rgba(240,237,230,.2);
}
.sc-icon{font-size:36px;margin:-4px 0}
.sc-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:32px;letter-spacing:.04em;
}
.sc-sector{font-size:13px;color:var(--dim);font-style:italic;margin-top:-10px}

.sc-screens{
  display:flex;flex-direction:column;gap:8px;margin:4px 0;
}
.sc-screen-item{
  display:flex;align-items:center;gap:10px;
  font-size:13px;color:var(--dim);
}
.sc-screen-item::before{content:'→';color:var(--sc,var(--signal));flex-shrink:0;font-family:'DM Mono',monospace}

.sc-contents{
  display:flex;flex-wrap:wrap;gap:6px;
  border-top:1px solid var(--line);
  padding-top:16px;
}
.sc-tag{
  font-family:'DM Mono',monospace;font-size:8px;letter-spacing:.12em;
  border:1px solid rgba(240,237,230,.1);
  padding:4px 10px;
  color:rgba(240,237,230,.4);
  transition:all .2s;
}
.sector-card:hover .sc-tag{border-color:var(--sc,var(--signal));color:var(--sc,var(--signal))}

/* Wide card */
.sector-wide{
  grid-column:1 / -1;
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:0;
  background:transparent;
  padding:0;
}
.sector-wide-inner{
  background:var(--ink);
  padding:48px 40px;
  border-right:2px solid var(--line);
  position:relative;overflow:hidden;
  transition:background .3s;
}
.sector-wide-inner:last-child{border-right:none}
.sector-wide-inner:hover{background:var(--card-bg)}
.sector-wide-inner::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--sc,var(--signal));
  transform:scaleX(0);transform-origin:left;transition:transform .35s;
}
.sector-wide-inner:hover::before{transform:scaleX(1)}

/* ══════════════════════════════
   CONTENIDOS QUE SE MUESTRAN
══════════════════════════════ */
.contents-section{
  padding:120px 60px;
  background:var(--paper);
  color:var(--ink);
  border-top:4px solid var(--signal);
}
.contents-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.3em;color:var(--signal);margin-bottom:20px}
.contents-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(48px,7vw,100px);
  line-height:.9;
  margin-bottom:60px;
}

.contents-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:24px;
}
.content-card{
  background:#fff;
  padding:32px 28px;
  border:1px solid rgba(8,8,12,.06);
  position:relative;
  overflow:hidden;
  transition:all .3s ease;
}
.content-card:hover{transform:translateY(-6px);box-shadow:0 24px 60px rgba(8,8,12,.12)}
.content-card::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:3px;
  background:var(--cc,var(--signal));
}
.cc-icon{font-size:40px;margin-bottom:16px;display:block}
.cc-name{
  font-family:'Bebas Neue',sans-serif;
  font-size:26px;letter-spacing:.04em;
  margin-bottom:8px;
}
.cc-desc{font-size:13px;color:#666;line-height:1.65}

/* ══════════════════════════════
   WHY / IMPACTO
══════════════════════════════ */
.impact{padding:120px 60px;border-top:1px solid var(--line)}
.impact-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.3em;color:var(--signal);margin-bottom:20px}
.impact-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(42px,6vw,84px);
  line-height:.95;
  margin-bottom:80px;
}
.impact-title .warm{color:var(--warm)}

.impact-grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:2px;
  background:var(--line);
  margin-bottom:80px;
}
.impact-block{
  background:var(--ink);
  padding:60px 52px;
  display:flex;gap:32px;align-items:flex-start;
  transition:background .3s;
}
.impact-block:hover{background:var(--card-bg)}
.ib-number{
  font-family:'Bebas Neue',sans-serif;
  font-size:72px;
  line-height:1;
  color:var(--signal);
  flex-shrink:0;
  min-width:90px;
}
.ib-title{
  font-family:'Familjen Grotesk',sans-serif;
  font-weight:700;font-size:20px;
  margin-bottom:10px;
}
.ib-desc{font-size:14px;color:var(--dim);line-height:1.7}

/* Quote block */
.quote-block{
  border-left:4px solid var(--signal);
  padding:40px 52px;
  background:rgba(255,45,0,.04);
}
.quote-text{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(28px,4vw,52px);
  line-height:1.05;
  margin-bottom:16px;
}
.quote-text .hl{color:var(--warm)}
.quote-attr{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.2em;color:var(--dim)}

/* ══════════════════════════════
   TECH / CÓMO FUNCIONA
══════════════════════════════ */
.how{padding:120px 60px;border-top:1px solid var(--line);background:var(--card-bg)}
.how-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.3em;color:var(--cool);margin-bottom:20px}
.how-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(42px,6vw,84px);
  line-height:.95;
  margin-bottom:72px;
}
.how-title .cool{color:var(--cool)}

.how-flow{
  display:grid;
  grid-template-columns:repeat(5,1fr);
  position:relative;
  gap:0;
}
.how-flow::after{
  content:'';position:absolute;
  top:40px;left:10%;right:10%;height:1px;
  background:linear-gradient(90deg,var(--signal),var(--cool));
  opacity:.3;
}
.how-step{
  padding:0 24px;text-align:center;position:relative;
}
.hs-dot{
  width:80px;height:80px;
  margin:0 auto 24px;
  background:var(--ink);
  border:1px solid;
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:26px;
  position:relative;z-index:1;
  transition:all .3s;
}
.how-step:hover .hs-dot{transform:scale(1.1)}
.hs-num{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.2em;color:var(--dim);margin-bottom:6px}
.hs-name{font-family:'Familjen Grotesk',sans-serif;font-weight:700;font-size:14px;margin-bottom:6px}
.hs-detail{font-size:12px;color:var(--dim);line-height:1.6}

/* ══════════════════════════════
   CTA FINAL
══════════════════════════════ */
.cta-final{
  padding:120px 60px;
  background:var(--signal);
  color:#fff;
  display:grid;
  grid-template-columns:1fr auto;
  gap:60px;
  align-items:center;
  position:relative;overflow:hidden;
}
.cta-final::before{
  content:'SIGNAL';
  font-family:'Bebas Neue',sans-serif;
  font-size:30vw;
  position:absolute;
  right:-5vw;top:50%;transform:translateY(-50%);
  color:rgba(255,255,255,.06);
  pointer-events:none;
  line-height:1;
}
.cta-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.3em;opacity:.6;margin-bottom:16px}
.cta-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(42px,6vw,80px);
  line-height:.95;
}
.cta-sub{font-size:16px;opacity:.75;margin-top:16px;max-width:480px;line-height:1.6}
.cta-btns{display:flex;flex-direction:column;gap:12px;flex-shrink:0;position:relative;z-index:1}
.btn-white{
  background:#fff;color:var(--signal);
  font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.15em;font-weight:500;
  padding:16px 36px;border:none;
  transition:all .25s;text-decoration:none;display:block;text-align:center;
}
.btn-white:hover{background:var(--ink);color:#fff}
.btn-outline-w{
  border:2px solid rgba(255,255,255,.5);color:#fff;
  font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.15em;
  padding:14px 36px;transition:all .25s;text-decoration:none;display:block;text-align:center;
}
.btn-outline-w:hover{border-color:#fff}

/* ── FOOTER ── */
footer{
  padding:48px 60px;
  display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid var(--line);
}
.f-logo{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.1em}
.f-logo span{color:var(--signal)}
.f-copy{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.15em;color:var(--dim)}

/* ── UTILS ── */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
.reveal.in{opacity:1;transform:none}

@media(max-width:1024px){
  nav{padding:20px 24px}
  .nav-links{display:none}
  .hero-h1{font-size:clamp(56px,16vw,120px)}
  section,.statement,.sectors,.impact,.how,.cta-final,.contents-section,.demo-section{padding-left:24px;padding-right:24px}
